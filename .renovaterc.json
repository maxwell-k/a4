{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assignees": ["maxwell-k"],
  "extends": ["config:best-practices"],
  "customManagers": [
    {
      "customType": "regex",
      "matchStrings": [
        "{ deno-version: (?<currentValue>.+?) } # see [.]renovaterc[.]json"
      ],
      "managerFilePatterns": ["/^[.]github[/]workflows[/]main[.]yaml$/"],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "deno",
      "packageNameTemplate": "denoland/deno"
    }
  ],
  "packageRules": [
    {
      "description": "Ignore Deno versions picked up by github-actions from npm; Deno upstream doesn't always publish versions to npm",
      "matchPackageNames": ["deno"],
      "matchDatasources": ["npm"],
      "matchManagers": ["github-actions"],
      "enabled": false
    },
    {
      "description": "Automerge upgrades to GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "description": "Automerge upgrades to package.json",
      "matchFileNames": ["package.json"],
      "automerge": true
    }
  ]
}
